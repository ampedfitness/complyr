{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ampedfitness/complyr/schema/authorities.schema.json",
  "title": "Complyr authorities registry",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["id", "name", "name_ar", "jurisdiction", "type", "mandate", "website"],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^(bh|sa|ae|qa|kw|om|gcc)-[a-z0-9]+(-[a-z0-9]+)*$"
      },
      "name": { "type": "string", "minLength": 3 },
      "name_ar": { "type": ["string", "null"], "minLength": 3 },
      "jurisdiction": { "enum": ["BH", "SA", "AE", "QA", "KW", "OM"] },
      "type": {
        "enum": ["ministry", "sectoral_regulator", "central_bank", "cabinet", "head_of_state", "free_zone_authority", "government_agency", "head_of_government", "legislature", "council", "government"]
      },
      "mandate": { "type": "string", "minLength": 20, "description": "One sentence describing what the body regulates" },
      "website": { "type": ["string", "null"], "format": "uri" }
    }
  }
}
