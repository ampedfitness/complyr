---
import type { Jurisdiction } from '../lib/types';

interface Props {
  code: Jurisdiction;
}

const { code } = Astro.props;

// Simplified flag geometry, enough to read at small sizes.
const flags: Record<Jurisdiction, string> = {
  BH: `<rect width="20" height="14" fill="#ce1126"/>
    <path d="M0 0h7l2.6 1.4L7 2.8l2.6 1.4L7 5.6 9.6 7 7 8.4l2.6 1.4L7 11.2l2.6 1.4L7 14H0Z" fill="#fff"/>`,
  SA: `<rect width="20" height="14" fill="#165d31"/>
    <rect x="5" y="4.6" width="10" height="1.6" rx="0.8" fill="#fff"/>
    <rect x="5.6" y="8.2" width="8.8" height="1.1" rx="0.55" fill="#fff"/>`,
  AE: `<rect width="20" height="14" fill="#00732f"/>
    <rect y="4.67" width="20" height="4.66" fill="#fff"/>
    <rect y="9.33" width="20" height="4.67" fill="#000"/>
    <rect width="5.5" height="14" fill="#ff0000"/>`,
  QA: `<rect width="20" height="14" fill="#8a1538"/>
    <path d="M0 0h7l2.6 1L7 2l2.6 1L7 4l2.6 1L7 6l2.6 1L7 8l2.6 1L7 10l2.6 1L7 12l2.6 1L7 14H0Z" fill="#fff"/>`,
  KW: `<rect width="20" height="14" fill="#007a3d"/>
    <rect y="4.67" width="20" height="4.66" fill="#fff"/>
    <rect y="9.33" width="20" height="4.67" fill="#ce1126"/>
    <path d="M0 0 6 4.67v4.66L0 14Z" fill="#000"/>`,
  OM: `<rect width="20" height="14" fill="#fff"/>
    <rect y="4.67" width="20" height="4.66" fill="#db161b"/>
    <rect y="9.33" width="20" height="4.67" fill="#008000"/>
    <rect width="5.5" height="14" fill="#db161b"/>`,
};
---

<span class="flag" aria-hidden="true">
  <svg viewBox="0 0 20 14" set:html={flags[code]} />
</span>

<style>
  .flag {
    display: inline-flex;
    flex-shrink: 0;
    width: 1.5rem;
    height: 1.05rem;
    border-radius: 3px;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--ink) 14%, transparent);
  }

  .flag svg {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>
