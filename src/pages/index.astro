---
import Base from '../layouts/Base.astro';
import Flag from '../components/Flag.astro';
import { dataset, stats } from '../lib/data';
import { JURISDICTION_NAMES } from '../lib/labels';
import type { DocRecord, Jurisdiction } from '../lib/types';

const base = import.meta.env.BASE_URL;
const classLabels = new Map(dataset.instrumentClasses.map((c) => [c.id, c.label]));

const monthLabel = (iso: string) =>
  new Date(`${iso}-15T00:00:00Z`).toLocaleString('en-US', {
    month: 'long',
    timeZone: 'UTC',
  });

const dayLabel = (iso: string) =>
  new Date(`${iso}T00:00:00Z`).toLocaleString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
    timeZone: 'UTC',
  });

const firstSentence = (text: string) => {
  const idx = text.indexOf('. ');
  return idx === -1 ? text : text.slice(0, idx + 1);
};

const groups: { month: string; name: string; year: string; docs: DocRecord[] }[] = [];
for (const doc of dataset.documents) {
  const month = doc.date_issued.slice(0, 7);
  const group = groups.find((g) => g.month === month);
  if (group) group.docs.push(doc);
  else
    groups.push({
      month,
      name: monthLabel(month),
      year: doc.date_issued.slice(0, 4),
      docs: [doc],
    });
}
const lead = groups[0];
const rest = groups.slice(1, 4);

const typeChips = (docs: DocRecord[]) => {
  const counts = new Map<string, number>();
  for (const d of docs) {
    const label = classLabels.get(d.instrument_class) ?? d.instrument_class;
    counts.set(label, (counts.get(label) ?? 0) + 1);
  }
  return [...counts.entries()].map(([label, n]) => `${n} ${label}`);
};

const confidence = (doc: DocRecord) =>
  doc.source_confidence === 'official'
    ? { cls: 'high', label: 'High' }
    : doc.source_confidence === 'secondary'
      ? { cls: 'medium', label: 'Medium' }
      : { cls: 'pending', label: 'Pending' };

const ALL: Jurisdiction[] = ['BH', 'SA', 'AE', 'QA', 'KW', 'OM'];
const jurCounts = ALL.map((j) => ({
  code: j,
  name: JURISDICTION_NAMES[j],
  count: dataset.documents.filter((d) => d.jurisdiction === j).length,
}));

const categoryCount = dataset.branches.length;
const subcategoryCount = dataset.branches.reduce((n, b) => n + b.children.length, 0);
const coverage = stats.dateRange
  ? `${stats.dateRange.from.slice(0, 4)}–${stats.dateRange.to.slice(0, 4)}`
  : '—';

const statCards = [
  {
    label: 'Est. year',
    value: '2026',
    icon: 'M7 3v3M17 3v3M4 7.5h16M5.5 5h13A1.5 1.5 0 0 1 20 6.5v12a1.5 1.5 0 0 1-1.5 1.5h-13A1.5 1.5 0 0 1 4 18.5v-12A1.5 1.5 0 0 1 5.5 5Z',
  },
  {
    label: 'Total instruments',
    value: String(stats.entries),
    icon: 'M14 3H7a1.5 1.5 0 0 0-1.5 1.5v15A1.5 1.5 0 0 0 7 21h10a1.5 1.5 0 0 0 1.5-1.5V7.5L14 3ZM14 3v4.5h4.5M9 12h6M9 15.5h6',
  },
  {
    label: 'Authorities',
    value: String(stats.authorities),
    icon: 'M3 21h18M5 21v-9M19 21v-9M9 21v-9M15 21v-9M3 9l9-6 9 6M3 9h18',
  },
  {
    label: 'Coverage',
    value: coverage,
    icon: 'M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18ZM3 12h18M12 3a13.5 13.5 0 0 1 0 18M12 3a13.5 13.5 0 0 0 0 18',
  },
];

const axes = [
  {
    name: 'Instrument class',
    desc: 'What it is by legal form, split first by binding force.',
    icon: 'M12 4v16M8 20h8M12 6 6 7.5M12 6l6 1.5M6 7.5l-2.5 6a3 3 0 0 0 5 0l-2.5-6ZM18 7.5l-2.5 6a3 3 0 0 0 5 0l-2.5-6Z',
  },
  {
    name: 'Themes',
    desc: `What it covers: ${categoryCount} categories and ${subcategoryCount} subcategories.`,
    icon: 'M5 5h5v5H5zM14 5h5v5h-5zM5 14h5v5H5zM14 14h5v5h-5z',
  },
  {
    name: 'Lifecycle',
    desc: 'Where it is in its lifecycle, from consultation to force and beyond.',
    icon: 'M20 12a8 8 0 1 1-2.3-5.6M20 4v4h-4',
  },
];

const legend = [
  { cls: 'high', name: 'High confidence', desc: 'Verified against an authoritative source' },
  { cls: 'medium', name: 'Medium confidence', desc: 'Verified against a secondary source' },
  { cls: 'pending', name: 'Pending verification', desc: 'Source confirmation in progress' },
  { cls: 'info', name: 'All entries are source linked', desc: 'Transparency by design' },
];

const chips = [
  { label: 'AI governance', href: `${base}dashboard/?l=ai_emerging_tech.ai_governance_ethics` },
  { label: 'Personal data protection', href: `${base}dashboard/?l=data_privacy.personal_data_protection` },
  { label: 'Cybersecurity', href: `${base}dashboard/?b=cybersecurity` },
  { label: 'Digital finance', href: `${base}dashboard/?b=digital_finance` },
];
---

<Base
  title="Complyr | GCC digital regulation, verified, structured, open"
  description="An open source structured dataset and taxonomy of GCC digital regulation: data, AI, cybersecurity, telecom, digital government, platforms, digital finance, online content, and digital health."
>
  <div class="home">
    <script is:inline>
      if (
        'IntersectionObserver' in window &&
        !matchMedia('(prefers-reduced-motion: reduce)').matches
      ) {
        document.documentElement.classList.add('js-reveal');
      }
    </script>
    <section class="hero">
      <h1 class="reveal">GCC Digital Regulation. Verified. Structured.&nbsp;Open.</h1>
      <p class="hero-lede reveal d1">
        A structured, source-verified register of digital regulatory instruments across Bahrain,
        Saudi Arabia, UAE, Qatar, Kuwait, and Oman.
      </p>
      <form class="search reveal d2" role="search" action={`${base}dashboard/`} method="get">
        <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7" />
          <path d="m20 20-3.5-3.5" />
        </svg>
        <input
          id="home-search"
          type="search"
          name="q"
          placeholder="Search laws, regulations, strategies across the GCC…"
          aria-label="Search the register"
          enterkeyhint="search"
          autocomplete="off"
        />
        <span class="kbd" aria-hidden="true">/</span>
        <button class="search-go" type="submit" aria-label="Search">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" />
          </svg>
        </button>
      </form>
      <div class="chips reveal d3">
        {chips.map((c) => <a class="chip" href={c.href}>{c.label}</a>)}
      </div>
    </section>

    <div class="stat-row reveal d4">
      {
        statCards.map((s) => (
          <div class="stat-card">
            <svg class="stat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d={s.icon} />
            </svg>
            <span class="stat-label">{s.label}</span>
            <span class="stat-value">{s.value}</span>
          </div>
        ))
      }
    </div>

    <div class="classify reveal d5">
      <h2>How Complyr classifies regulation</h2>
      <div class="classify-axes">
        {
          axes.map((a) => (
            <div class="axis">
              <svg class="axis-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d={a.icon} />
              </svg>
              <span class="axis-name">{a.name}</span>
              <span class="axis-desc">{a.desc}</span>
            </div>
          ))
        }
      </div>
    </div>

    <section class="jurisdictions" data-reveal aria-label="Jurisdictions">
      <h2 class="zone-title">Browse by jurisdiction</h2>
      <div class="jur-grid">
        {
          jurCounts.map((j) => (
            <a class="jur-tile" href={`${base}dashboard/?c=${j.code}`}>
              <span class="jur-head">
                <Flag code={j.code} />
                <span class="jur-names">
                  <span class="jur-code">{j.code}</span>
                  <span class="jur-name">{j.name}</span>
                </span>
              </span>
              <span class="jur-foot">
                <span class="jur-count">
                  {j.count} {j.count === 1 ? 'instrument' : 'instruments'}
                </span>
                <span class="go" aria-hidden="true">&rarr;</span>
              </span>
            </a>
          ))
        }
      </div>
    </section>

    <section class="updates-zone" data-reveal>
      <div class="updates-card">
        <div class="updates-head">
          <span class="pulse-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 12h4l2.5-7 5 14 2.5-7h4" />
            </svg>
          </span>
          <div class="updates-titles">
            <h2>Latest updates</h2>
            <p>Track the most recent regulatory developments across the GCC.</p>
          </div>
          <a class="dash-link" href={`${base}dashboard/`}>View full dashboard &rarr;</a>
        </div>

        <div class="timeline">
          <article class="month-block lead">
            <header class="month-head">
              <h3>{lead.name} {lead.year}</h3>
              <span class="newest-tag">Newest</span>
              <span class="month-count">
                {lead.docs.length} {lead.docs.length === 1 ? 'update' : 'updates'}
              </span>
            </header>
            <div class="update-table">
              <div class="update-row head" aria-hidden="true">
                <span>Date</span>
                <span>Jurisdiction</span>
                <span>Type</span>
                <span>Title &amp; summary</span>
                <span class="conf-col">Source confidence</span>
                <span></span>
              </div>
              {
                lead.docs.map((doc) => {
                  const conf = confidence(doc);
                  return (
                    <a class="update-row" href={`${base}dashboard/?q=${encodeURIComponent(doc.title)}`}>
                      <span class="u-date">{dayLabel(doc.date_issued)}</span>
                      <span class="u-jur">
                        <Flag code={doc.jurisdiction} />
                        {doc.jurisdiction}
                      </span>
                      <span class="u-type">
                        <span class="pill">{classLabels.get(doc.instrument_class) ?? doc.instrument_class}</span>
                      </span>
                      <span class="u-title">
                        <span class="u-name">{doc.title}</span>
                        <span class="u-line">{firstSentence(doc.summary)}</span>
                      </span>
                      <span class={`conf ${conf.cls} conf-col`}>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <path d="M12 3 5 5.5v5c0 4.5 3 8.5 7 10 4-1.5 7-5.5 7-10v-5L12 3Z" />
                          <path d="m9 11.5 2 2 4-4" />
                        </svg>
                        {conf.label}
                      </span>
                      <span class="go" aria-hidden="true">&rarr;</span>
                    </a>
                  );
                })
              }
            </div>
          </article>

          {
            rest.map((group) => (
              <details class="month-block">
                <summary>
                  <h3>{group.name} {group.year}</h3>
                  <span class="month-count">
                    {group.docs.length} {group.docs.length === 1 ? 'update' : 'updates'}
                  </span>
                  <span class="type-chips">
                    {typeChips(group.docs).map((chip) => (
                      <span class="type-chip">{chip}</span>
                    ))}
                  </span>
                  <svg class="chev" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="m4 6 4 4 4-4" />
                  </svg>
                </summary>
                <div class="update-table">
                  {group.docs.map((doc) => {
                    const conf = confidence(doc);
                    return (
                      <a class="update-row" href={`${base}dashboard/?q=${encodeURIComponent(doc.title)}`}>
                        <span class="u-date">{dayLabel(doc.date_issued)}</span>
                        <span class="u-jur">
                          <Flag code={doc.jurisdiction} />
                          {doc.jurisdiction}
                        </span>
                        <span class="u-type">
                          <span class="pill">{classLabels.get(doc.instrument_class) ?? doc.instrument_class}</span>
                        </span>
                        <span class="u-title">
                          <span class="u-name">{doc.title}</span>
                        </span>
                        <span class={`conf ${conf.cls} conf-col`}>
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M12 3 5 5.5v5c0 4.5 3 8.5 7 10 4-1.5 7-5.5 7-10v-5L12 3Z" />
                            <path d="m9 11.5 2 2 4-4" />
                          </svg>
                          {conf.label}
                        </span>
                        <span class="go" aria-hidden="true">&rarr;</span>
                      </a>
                    );
                  })}
                </div>
              </details>
            ))
          }
        </div>

        <ul class="legend">
          {
            legend.map((l) => (
              <li>
                <span class={`conf ${l.cls}`}>
                  {l.cls === 'info' ? (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <circle cx="12" cy="12" r="9" />
                      <path d="M12 11v5M12 8h.01" />
                    </svg>
                  ) : (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M12 3 5 5.5v5c0 4.5 3 8.5 7 10 4-1.5 7-5.5 7-10v-5L12 3Z" />
                      <path d="m9 11.5 2 2 4-4" />
                    </svg>
                  )}
                </span>
                <span class="legend-text">
                  <span class="legend-name">{l.name}</span>
                  <span class="legend-desc">{l.desc}</span>
                </span>
              </li>
            ))
          }
        </ul>
      </div>

    </section>
  </div>
</Base>

<script>
  const search = document.getElementById('home-search');
  window.addEventListener('keydown', (e) => {
    if (e.key !== '/' || e.ctrlKey || e.metaKey || e.altKey) return;
    const t = e.target as HTMLElement | null;
    if (t && (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.isContentEditable)) return;
    e.preventDefault();
    search?.focus();
  });

  const targets = document.querySelectorAll('[data-reveal]');
  if (document.documentElement.classList.contains('js-reveal')) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('shown');
            io.unobserve(entry.target);
          }
        }
      },
      { rootMargin: '0px 0px -8% 0px' }
    );
    targets.forEach((el) => io.observe(el));
  }
</script>

<style>
  .home {
    display: grid;
    gap: 2.6rem;
    overflow-x: clip;
  }

  /* Hero */
  .hero {
    position: relative;
    max-width: 46rem;
    margin: 1.4rem auto 0;
    display: grid;
    gap: 1.15rem;
    justify-items: center;
    text-align: center;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: -30% -20% auto;
    height: 150%;
    background: radial-gradient(
      40rem 20rem at 50% 32%,
      color-mix(in srgb, var(--accent) 9%, transparent),
      transparent 70%
    );
    pointer-events: none;
    z-index: -1;
  }

  .hero h1 {
    font-size: clamp(2.2rem, 5vw, 3.3rem);
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1.06;
    margin: 0;
  }

  .hero-lede {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--ink-soft);
    margin: 0;
    max-width: 36rem;
  }

  /* Search */
  .search {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    width: 100%;
    max-width: 38rem;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 999px;
    box-shadow: var(--shadow);
    padding: 0.3rem 0.3rem 0.3rem 1.15rem;
    transition: border-color 160ms ease, box-shadow 200ms ease;
  }

  .search:focus-within {
    border-color: color-mix(in srgb, var(--accent) 55%, var(--line));
    box-shadow: 0 0 0 4px var(--accent-soft), var(--shadow-lift);
  }

  .search-icon {
    width: 1.1rem;
    height: 1.1rem;
    color: var(--accent);
    flex-shrink: 0;
  }

  .search input {
    flex: 1;
    min-width: 0;
    border: 0;
    background: transparent;
    font: inherit;
    font-size: 0.95rem;
    color: var(--ink);
    padding: 0.55rem 0;
  }

  .search input::placeholder {
    color: var(--ink-faint);
  }

  .search input:focus {
    outline: none;
  }

  .kbd {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--ink-faint);
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 0.1rem 0.45rem;
    background: var(--paper);
    flex-shrink: 0;
  }

  .search-go {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    flex-shrink: 0;
    border: 0;
    border-radius: 999px;
    background: var(--accent);
    color: #ffffff;
    cursor: pointer;
  }

  .search-go:hover {
    background: var(--accent-strong);
  }

  .search-go svg {
    width: 1.1rem;
    height: 1.1rem;
  }

  :root[data-theme='dark'] .search-go {
    color: #0f0f17;
  }

  .chips {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    min-height: 2.75rem;
    padding: 0.3rem 1.05rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--accent);
    background: var(--accent-soft);
    border-radius: 999px;
  }

  .chip:hover {
    text-decoration: none;
    background: color-mix(in srgb, var(--accent) 14%, var(--accent-soft));
    transform: translateY(-1px);
  }

  @media (hover: none) {
    .kbd {
      display: none;
    }
  }

  /* Stat cards */
  .stat-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.9rem;
    max-width: 54rem;
    margin: 2.4rem auto 0;
  }

  .stat-card {
    display: grid;
    justify-items: start;
    gap: 0.15rem;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r);
    box-shadow: var(--shadow);
    padding: 0.95rem 1.05rem;
  }

  .stat-icon {
    width: 1.25rem;
    height: 1.25rem;
    color: var(--accent);
    margin-bottom: 0.3rem;
  }

  .stat-label {
    font-size: 0.74rem;
    font-weight: 500;
    color: var(--ink-faint);
  }

  .stat-value {
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--ink);
    font-variant-numeric: tabular-nums;
  }

  /* Classification panel */
  .classify {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r);
    box-shadow: var(--shadow);
    padding: 1.2rem 1.4rem 1.35rem;
    max-width: 54rem;
    margin: 0.9rem auto 0;
  }

  .classify h2 {
    font-size: 1.02rem;
    font-weight: 700;
    margin: 0 0 1rem;
  }

  .classify-axes {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }

  .axis {
    display: grid;
    justify-items: center;
    text-align: center;
    gap: 0.2rem;
    padding: 0 1.1rem;
  }

  .axis + .axis {
    border-left: 1px solid var(--line);
  }

  .axis-icon {
    width: 1.5rem;
    height: 1.5rem;
    color: var(--accent);
    margin-bottom: 0.35rem;
  }

  .axis:nth-child(3) .axis-icon {
    color: var(--ok);
  }

  .axis-name {
    font-size: 0.87rem;
    font-weight: 600;
    color: var(--ink);
  }

  .axis-desc {
    font-size: 0.78rem;
    line-height: 1.5;
    color: var(--ink-faint);
  }

  /* Jurisdiction tiles */
  .zone-title {
    font-size: 1.15rem;
    font-weight: 700;
    margin: 0 0 0.9rem;
  }

  .jur-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 0.9rem;
  }

  .jur-tile {
    display: grid;
    gap: 0.8rem;
    align-content: space-between;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r);
    box-shadow: var(--shadow);
    padding: 0.95rem 1rem;
    color: var(--ink);
  }

  .jur-tile:hover {
    text-decoration: none;
    border-color: color-mix(in srgb, var(--accent) 40%, var(--line));
    box-shadow: var(--shadow-lift);
    transform: translateY(-2px);
  }

  @media (prefers-reduced-motion: no-preference) {
    .jur-tile {
      transition: border-color 140ms ease, box-shadow 180ms ease, transform 180ms ease;
    }
  }

  .jur-head {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .jur-names {
    display: grid;
    line-height: 1.3;
  }

  .jur-code {
    font-size: 0.85rem;
    font-weight: 700;
  }

  .jur-name {
    font-size: 0.78rem;
    color: var(--ink-soft);
  }

  .jur-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.76rem;
    color: var(--ink-faint);
  }

  .go {
    color: var(--accent);
    font-weight: 600;
  }

  .jur-tile:hover .go {
    transform: translateX(2px);
  }

  /* Updates zone */
  .updates-zone {
    display: block;
  }

