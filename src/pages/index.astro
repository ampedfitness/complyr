---
import Base from '../layouts/Base.astro';
import Flag from '../components/Flag.astro';
import { dataset, stats } from '../lib/data';
import { JURISDICTION_NAMES } from '../lib/labels';
import type { DocRecord, Jurisdiction } from '../lib/types';

const base = import.meta.env.BASE_URL;
const classLabels = new Map(dataset.instrumentClasses.map((c) => [c.id, c.label]));

const monthLabel = (iso: string) =>
  new Date(`${iso}-15T00:00:00Z`).toLocaleString('en-US', {
    month: 'long',
    timeZone: 'UTC',
  });

const dayLabel = (iso: string) =>
  new Date(`${iso}T00:00:00Z`).toLocaleString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
    timeZone: 'UTC',
  });

const firstSentence = (text: string) => {
  const idx = text.indexOf('. ');
  return idx === -1 ? text : text.slice(0, idx + 1);
};

const groups: { month: string; name: string; year: string; docs: DocRecord[] }[] = [];
for (const doc of dataset.documents) {
  const month = doc.date_issued.slice(0, 7);
  const group = groups.find((g) => g.month === month);
  if (group) group.docs.push(doc);
  else
    groups.push({
      month,
      name: monthLabel(month),
      year: doc.date_issued.slice(0, 4),
      docs: [doc],
    });
}
const lead = groups[0];
const rest = groups.slice(1, 4);

const typeChips = (docs: DocRecord[]) => {
  const counts = new Map<string, number>();
  for (const d of docs) {
    const label = classLabels.get(d.instrument_class) ?? d.instrument_class;
    counts.set(label, (counts.get(label) ?? 0) + 1);
  }
  return [...counts.entries()].map(([label, n]) => `${n} ${label}`);
};

const confidence = (doc: DocRecord) =>
  doc.source_confidence === 'official'
    ? { cls: 'high', label: 'High' }
    : doc.source_confidence === 'secondary'
      ? { cls: 'medium', label: 'Medium' }
      : { cls: 'pending', label: 'Pending' };

const ALL: Jurisdiction[] = ['BH', 'SA', 'AE', 'QA', 'KW', 'OM'];
const jurCounts = ALL.map((j) => ({
  code: j,
  name: JURISDICTION_NAMES[j],
  count: dataset.documents.filter((d) => d.jurisdiction === j).length,
}));

const categoryCount = dataset.branches.length;
const subcategoryCount = dataset.branches.reduce((n, b) => n + b.children.length, 0);
const coverage = stats.dateRange
  ? `${stats.dateRange.from.slice(0, 4)}–${stats.dateRange.to.slice(0, 4)}`
  : '—';

const statCards = [
  {
    label: 'Est. year',
    value: '2026',
    icon: 'M7 3v3M17 3v3M4 7.5h16M5.5 5h13A1.5 1.5 0 0 1 20 6.5v12a1.5 1.5 0 0 1-1.5 1.5h-13A1.5 1.5 0 0 1 4 18.5v-12A1.5 1.5 0 0 1 5.5 5Z',
  },
  {
    label: 'Total instruments',
    value: String(stats.entries),
    icon: 'M14 3H7a1.5 1.5 0 0 0-1.5 1.5v15A1.5 1.5 0 0 0 7 21h10a1.5 1.5 0 0 0 1.5-1.5V7.5L14 3ZM14 3v4.5h4.5M9 12h6M9 15.5h6',
  },
  {
    label: 'Authorities',
    value: String(stats.authorities),
    icon: 'M3 21h18M5 21v-9M19 21v-9M9 21v-9M15 21v-9M3 9l9-6 9 6M3 9h18',
  },
  {
    label: 'Coverage',
    value: coverage,
    icon: 'M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18ZM3 12h18M12 3a13.5 13.5 0 0 1 0 18M12 3a13.5 13.5 0 0 0 0 18',
  },
];

const axes = [
  {
    name: 'Instrument class',
    desc: 'What it is by legal form, split first by binding force.',
    icon: 'M12 4v16M8 20h8M12 6 6 7.5M12 6l6 1.5M6 7.5l-2.5 6a3 3 0 0 0 5 0l-2.5-6ZM18 7.5l-2.5 6a3 3 0 0 0 5 0l-2.5-6Z',
  },
  {
    name: 'Themes',
    desc: `What it covers: ${categoryCount} categories and ${subcategoryCount} subcategories.`,
    icon: 'M5 5h5v5H5zM14 5h5v5h-5zM5 14h5v5H5zM14 14h5v5h-5z',
  },
  {
    name: 'Lifecycle',
    desc: 'Where it is in its lifecycle, from consultation to force and beyond.',
    icon: 'M20 12a8 8 0 1 1-2.3-5.6M20 4v4h-4',
  },
];

const legend = [
  { cls: 'high', name: 'High confidence', desc: 'Verified against an authoritative source' },
  { cls: 'medium', name: 'Medium confidence', desc: 'Verified against a secondary source' },
  { cls: 'pending', name: 'Pending verification', desc: 'Source confirmation in progress' },
  { cls: 'info', name: 'All entries are source linked', desc: 'Transparency by design' },
];
---

<Base
  title="Complyr | GCC digital regulation, verified, structured, open"
  description="An open source structured dataset and taxonomy of GCC digital regulation: data, AI, cybersecurity, telecom, digital government, platforms, digital finance, online content, and digital health."
>
  <div class="home">
    <section class="hero">
      <div class="hero-copy reveal">
        <h1>GCC Digital Regulation. Verified. Structured.&nbsp;Open.</h1>
        <p class="hero-ar" lang="ar" dir="rtl">
          التنظيمات الرقمية في دول مجلس التعاون الخليجي. موثقة. منظمة. ومفتوحة.
        </p>
        <p class="hero-lede">
          GCC digital regulation lives in scattered PDFs across six jurisdictions and two
          languages, with no machine readable way to say what an instrument is, whether it binds,
          and what it amends.
        </p>
        <p class="hero-lede">
          Complyr solves this by providing a structured, source-verified register of digital
          regulatory instruments across Bahrain, Saudi Arabia, UAE, Qatar, Kuwait, and Oman.
        </p>
      </div>
      <div class="hero-side">
        <div class="stat-row reveal d1">
          {
            statCards.map((s) => (
              <div class="stat-card">
                <svg class="stat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={s.icon} />
                </svg>
                <span class="stat-label">{s.label}</span>
                <span class="stat-value">{s.value}</span>
              </div>
            ))
          }
        </div>
        <div class="classify reveal d2">
          <h2>How Complyr classifies regulation</h2>
          <div class="classify-axes">
            {
              axes.map((a) => (
                <div class="axis">
                  <svg class="axis-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d={a.icon} />
                  </svg>
                  <span class="axis-name">{a.name}</span>
                  <span class="axis-desc">{a.desc}</span>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section class="jurisdictions reveal d2" aria-label="Jurisdictions">
      <h2 class="zone-title">Browse by jurisdiction</h2>
      <div class="jur-grid">
        {
          jurCounts.map((j) => (
            <a class="jur-tile" href={`${base}dashboard/?c=${j.code}`}>
              <span class="jur-head">
                <Flag code={j.code} />
                <span class="jur-names">
                  <span class="jur-code">{j.code}</span>
                  <span class="jur-name">{j.name}</span>
                </span>
              </span>
              <span class="jur-foot">
                <span class="jur-count">
                  {j.count} {j.count === 1 ? 'instrument' : 'instruments'}
                </span>
                <span class="go" aria-hidden="true">&rarr;</span>
              </span>
            </a>
          ))
        }
      </div>
    </section>

    <section class="updates-zone">
      <div class="updates-card reveal d3">
        <div class="updates-head">
          <span class="pulse-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 12h4l2.5-7 5 14 2.5-7h4" />
            </svg>
          </span>
          <div class="updates-titles">
            <h2>Latest updates</h2>
            <p>Track the most recent regulatory developments across the GCC.</p>
          </div>
          <a class="dash-link" href={`${base}dashboard/`}>View full dashboard &rarr;</a>
        </div>

        <div class="timeline">
          <article class="month-block lead">
            <header class="month-head">
              <h3>{lead.name} {lead.year}</h3>
              <span class="newest-tag">Newest</span>
              <span class="month-count">
                {lead.docs.length} {lead.docs.length === 1 ? 'update' : 'updates'}
              </span>
            </header>
            <div class="update-table">
              <div class="update-row head" aria-hidden="true">
                <span>Date</span>
                <span>Jurisdiction</span>
                <span>Type</span>
                <span>Title &amp; summary</span>
                <span class="conf-col">Source confidence</span>
                <span></span>
              </div>
              {
                lead.docs.map((doc) => {
                  const conf = confidence(doc);
                  return (
                    <a class="update-row" href={`${base}dashboard/?q=${encodeURIComponent(doc.title)}`}>
                      <span class="u-date">{dayLabel(doc.date_issued)}</span>
                      <span class="u-jur">
                        <Flag code={doc.jurisdiction} />
                        {doc.jurisdiction}
                      </span>
                      <span class="u-type">
                        <span class="pill">{classLabels.get(doc.instrument_class) ?? doc.instrument_class}</span>
                      </span>
                      <span class="u-title">
                        <span class="u-name">{doc.title}</span>
                        <span class="u-line">{firstSentence(doc.summary)}</span>
                      </span>
                      <span class={`conf ${conf.cls} conf-col`}>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <path d="M12 3 5 5.5v5c0 4.5 3 8.5 7 10 4-1.5 7-5.5 7-10v-5L12 3Z" />
                          <path d="m9 11.5 2 2 4-4" />
                        </svg>
                        {conf.label}
                      </span>
                      <span class="go" aria-hidden="true">&rarr;</span>
                    </a>
                  );
                })
              }
            </div>
          </article>

          {
            rest.map((group) => (
              <details class="month-block">
                <summary>
                  <h3>{group.name} {group.year}</h3>
                  <span class="month-count">
                    {group.docs.length} {group.docs.length === 1 ? 'update' : 'updates'}
                  </span>
                  <span class="type-chips">
                    {typeChips(group.docs).map((chip) => (
                      <span class="type-chip">{chip}</span>
                    ))}
                  </span>
                  <svg class="chev" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="m4 6 4 4 4-4" />
                  </svg>
                </summary>
                <div class="update-table">
                  {group.docs.map((doc) => {
                    const conf = confidence(doc);
                    return (
                      <a class="update-row" href={`${base}dashboard/?q=${encodeURIComponent(doc.title)}`}>
                        <span class="u-date">{dayLabel(doc.date_issued)}</span>
                        <span class="u-jur">
                          <Flag code={doc.jurisdiction} />
                          {doc.jurisdiction}
                        </span>
                        <span class="u-type">
                          <span class="pill">{classLabels.get(doc.instrument_class) ?? doc.instrument_class}</span>
                        </span>
                        <span class="u-title">
                          <span class="u-name">{doc.title}</span>
                        </span>
                        <span class={`conf ${conf.cls} conf-col`}>
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M12 3 5 5.5v5c0 4.5 3 8.5 7 10 4-1.5 7-5.5 7-10v-5L12 3Z" />
                            <path d="m9 11.5 2 2 4-4" />
                          </svg>
                          {conf.label}
                        </span>
                        <span class="go" aria-hidden="true">&rarr;</span>
                      </a>
                    );
                  })}
                </div>
              </details>
            ))
          }
        </div>

        <ul class="legend">
          {
            legend.map((l) => (
              <li>
                <span class={`conf ${l.cls}`}>
                  {l.cls === 'info' ? (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <circle cx="12" cy="12" r="9" />
                      <path d="M12 11v5M12 8h.01" />
                    </svg>
                  ) : (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M12 3 5 5.5v5c0 4.5 3 8.5 7 10 4-1.5 7-5.5 7-10v-5L12 3Z" />
                      <path d="m9 11.5 2 2 4-4" />
                    </svg>
                  )}
                </span>
                <span class="legend-text">
                  <span class="legend-name">{l.name}</span>
                  <span class="legend-desc">{l.desc}</span>
                </span>
              </li>
            ))
          }
        </ul>
      </div>

      <aside class="contribute-card reveal d4">
        <h2>Contribute to Complyr</h2>
        <p class="contribute-lede">
          Open by design. Better together. Help us keep the register accurate and complete.
        </p>
        <ol class="steps">
          <li>
            <span class="step-num" aria-hidden="true">1</span>
            <span class="step-body">
              <span class="step-name">Find an issue or instrument to improve</span>
              <span class="step-desc">Browse open issues or propose a new instrument.</span>
            </span>
          </li>
          <li>
            <span class="step-num" aria-hidden="true">2</span>
            <span class="step-body">
              <span class="step-name">Make a change</span>
              <span class="step-desc">Fork the repo, add your changes, and open a pull request.</span>
            </span>
          </li>
          <li>
            <span class="step-num" aria-hidden="true">3</span>
            <span class="step-body">
              <span class="step-name">Review and publish</span>
              <span class="step-desc">Maintainers review, verify sources, and publish.</span>
            </span>
          </li>
        </ol>
        <a class="gh-btn" href="https://github.com/ampedfitness/complyr">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48v-1.7c-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.9 1.52 2.34 1.08 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.02a9.58 9.58 0 0 1 5 0c1.91-1.29 2.75-1.02 2.75-1.02.55 1.38.2 2.4.1 2.65.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.69-4.57 4.93.36.31.68.92.68 1.85v2.75c0 .27.18.58.69.48A10 10 0 0 0 12 2Z" />
          </svg>
          Contribute on GitHub
          <span aria-hidden="true">&nearr;</span>
        </a>
      </aside>
    </section>
  </div>
</Base>

<style>
  .home {
    display: grid;
    gap: 2.6rem;
  }

  /* Hero */
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.15fr);
    gap: 2.6rem;
    align-items: start;
  }

  .hero-copy h1 {
    font-size: clamp(2.2rem, 4.4vw, 3.2rem);
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1.08;
    margin: 0.4rem 0 0.9rem;
  }

  .hero-ar {
    font-family: var(--arabic);
    font-size: 1.18rem;
    font-weight: 600;
    color: var(--accent);
    margin: 0 0 1.4rem;
  }

  .hero-lede {
    font-size: 0.98rem;
    line-height: 1.7;
    color: var(--ink-soft);
    margin: 0 0 0.9rem;
    max-width: 34rem;
  }

  /* Stat cards */
  .stat-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.9rem;
  }

  .stat-card {
    display: grid;
    justify-items: start;
    gap: 0.15rem;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r);
    box-shadow: var(--shadow);
    padding: 0.95rem 1.05rem;
  }

  .stat-icon {
    width: 1.25rem;
    height: 1.25rem;
    color: var(--accent);
    margin-bottom: 0.3rem;
  }

  .stat-label {
    font-size: 0.74rem;
    font-weight: 500;
    color: var(--ink-faint);
  }

  .stat-value {
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--ink);
    font-variant-numeric: tabular-nums;
  }

  /* Classification panel */
  .classify {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r);
    box-shadow: var(--shadow);
    padding: 1.2rem 1.4rem 1.35rem;
    margin-top: 0.9rem;
  }

  .classify h2 {
    font-size: 1.02rem;
    font-weight: 700;
    margin: 0 0 1rem;
  }

  .classify-axes {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }

  .axis {
    display: grid;
    justify-items: center;
    text-align: center;
    gap: 0.2rem;
    padding: 0 1.1rem;
  }

  .axis + .axis {
    border-left: 1px solid var(--line);
  }

  .axis-icon {
    width: 1.5rem;
    height: 1.5rem;
    color: var(--accent);
    margin-bottom: 0.35rem;
  }

  .axis:nth-child(3) .axis-icon {
    color: var(--ok);
  }

  .axis-name {
    font-size: 0.87rem;
    font-weight: 600;
    color: var(--ink);
  }

  .axis-desc {
    font-size: 0.78rem;
    line-height: 1.5;
    color: var(--ink-faint);
  }

  /* Jurisdiction tiles */
  .zone-title {
    font-size: 1.15rem;
    font-weight: 700;
    margin: 0 0 0.9rem;
  }

  .jur-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 0.9rem;
  }

  .jur-tile {
    display: grid;
    gap: 0.8rem;
    align-content: space-between;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r);
    box-shadow: var(--shadow);
    padding: 0.95rem 1rem;
    color: var(--ink);
  }

  .jur-tile:hover {
    text-decoration: none;
    border-color: color-mix(in srgb, var(--accent) 40%, var(--line));
    box-shadow: var(--shadow-lift);
    transform: translateY(-2px);
  }

  @media (prefers-reduced-motion: no-preference) {
    .jur-tile {
      transition: border-color 140ms ease, box-shadow 180ms ease, transform 180ms ease;
    }
  }

  .jur-head {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .jur-names {
    display: grid;
    line-height: 1.3;
  }

  .jur-code {
    font-size: 0.85rem;
    font-weight: 700;
  }

  .jur-name {
    font-size: 0.78rem;
    color: var(--ink-soft);
  }

  .jur-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.76rem;
    color: var(--ink-faint);
  }

  .go {
    color: var(--accent);
    font-weight: 600;
  }

  .jur-tile:hover .go {
    transform: translateX(2px);
  }

  /* Updates zone */
  .updates-zone {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 19.5rem;
    gap: 1.4rem;
    align-items: start;
  }

  .updates-card,
  .contribute-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    box-shadow: var(--shadow);
    padding: 1.5rem 1.6rem;
  }

  .updates-head {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    margin-bottom: 1.3rem;
  }

  .pulse-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.4rem;
    height: 2.4rem;
    flex-shrink: 0;
    border-radius: 999px;
    background: var(--accent-soft);
    color: var(--accent);
  }

  .pulse-icon svg {
    width: 1.3rem;
    height: 1.3rem;
  }

  .updates-titles {
    flex: 1;
  }

  .updates-titles h2 {
    font-size: 1.15rem;
    font-weight: 700;
    margin: 0;
  }

  .updates-titles p {
    font-size: 0.85rem;
    color: var(--ink-faint);
    margin: 0.15rem 0 0;
  }

  .dash-link {
    font-size: 0.85rem;
    font-weight: 600;
    white-space: nowrap;
    padding-top: 0.25rem;
  }

  /* Timeline */
  .timeline {
    position: relative;
    padding-left: 1.6rem;
    display: grid;
    gap: 0.8rem;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 0.36rem;
    top: 0.6rem;
    bottom: 0.6rem;
    width: 2px;
    background: var(--line);
  }

  .month-block {
    position: relative;
  }

  .month-block::before {
    content: '';
    position: absolute;
    left: -1.6rem;
    top: 0.45rem;
    width: 0.8rem;
    height: 0.8rem;
    border-radius: 50%;
    background: var(--surface);
    border: 2px solid var(--line-strong);
  }

  .month-block.lead::before {
    border-color: var(--accent);
    background: var(--accent-soft);
  }

  .month-head {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    margin-bottom: 0.7rem;
  }

  .month-head h3,
  .month-block summary h3 {
    font-size: 1.05rem;
    font-weight: 700;
    margin: 0;
  }

  .newest-tag {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-soft);
    border-radius: 999px;
