---
// The developments page became the dashboard; keep the old URL working.
const target = `${import.meta.env.BASE_URL}dashboard/`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
    <title>Complyr dashboard</title>
  </head>
  <body>
    <p>This page moved to the <a href={target}>dashboard</a>.</p>
  </body>
</html>
